const res = await fetch("http://localhost:8000/api/passkey/login/options", {
  method: "POST",
  body: JSON.stringify({ username: "zoe" }),
  headers: { "Content-Type": "application/json" }
});
const options = await res.json();

const assertion = await navigator.credentials.get({ publicKey: options });

await fetch("http://localhost:8000/api/passkey/login/verify", {
  method: "POST",
  body: JSON.stringify({ username: "zoe", ...assertion }),
  headers: { "Content-Type": "application/json" }
});
